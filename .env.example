# MongoDB connection string (use a separate database/cluster from your app backend if you want full isolation)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/sevenbites-restaurants

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Auth
JWT_SECRET=replace_with_a_long_random_string

# Comma-separated list of frontend origins allowed to call this API
ALLOWED_ORIGINS=http://localhost:3000,https://sevenbites.com

PORT=5000
